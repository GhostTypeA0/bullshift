// stompClient will hold our WebSocket connection once we connect
let stompClient = null;

// just giving myself a quick temporary username for testing
let currentUser = "User" + Math.floor(Math.random() * 1000);

// sets up the WebSocket connection to the backend
function connectWebSocket() {
    // hitting the /ws endpoint we set up in Spring Boot
    const socket = new SockJS("http://localhost:8081/ws");
    stompClient = Stomp.over(socket);

    // actually connect to the WebSocket server
    stompClient.connect({}, () => {
        console.log("Connected to WebSocket");

        // once connected, subscribe to the main message channel
        // anything the backend broadcasts to /topic/messages will show up here
        stompClient.subscribe("/topic/messages", (msg) => {
            const message = JSON.parse(msg.body);
            addMessageToUI(message.sender + ": " + message.content);
        });
    });
}

// sends a message from the input box to the backend
function sendMessage() {
    const input = document.getElementById("messageInput");
    const text = input.value.trim();

    // don't send empty messages
    if (text === "") return;

    // this is the message format our backend expects
    const msg = {
        sender: currentUser,
        receiver: "global", // placeholder until we add private chats
        content: text
    };

    // send the message to the backend WebSocket controller
    stompClient.send("/app/sendMessage", {}, JSON.stringify(msg));

    // clear the input box after sending
    input.value = "";
}

// adds a message to the chat window
function addMessageToUI(text) {
    const messagesDiv = document.getElementById("messages");

    // create a new message bubble
    const msgElem = document.createElement("div");
    msgElem.className = "message";
    msgElem.textContent = text;

    // add it to the chat window
    messagesDiv.appendChild(msgElem);

    // auto-scroll to the newest message
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
}

// send button click handler
document.getElementById("sendBtn").addEventListener("click", sendMessage);

// allow pressing Enter to send messages too
document.getElementById("messageInput").addEventListener("keypress", (e) => {
    if (e.key === "Enter") sendMessage();
});

// loads all old messages from the database using the REST API
function loadHistory() {
    fetch("http://localhost:8081/api/messages")
        .then(res => res.json())
        .then(data => {
            // loop through all messages and add them to the UI
            data.forEach(m => {
                addMessageToUI(m.sender + ": " + m.content);
            });
        });
}

// run both on page load:
// 1. load old messages
// 2. connect to WebSocket for new ones
loadHistory();
connectWebSocket();

